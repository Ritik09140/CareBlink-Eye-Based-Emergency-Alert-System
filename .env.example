# CareBlink Server Configuration
FLASK_ENV=development
FLASK_PORT=5000
SECRET_KEY=replace_with_a_long_secure_random_string

# Database configuration (Defaults to local SQLite if MySQL fails)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=careblink
DB_SQLITE_PATH=careblink.db

# Email Alert Dispatch (SMTP settings)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_smtp_app_password
SMTP_TO=destination_nurse_alerts@domain.com

# SMS Alert Dispatch (Twilio credentials)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890
TWILIO_TO_NUMBER=+1987654321
